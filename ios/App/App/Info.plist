<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>Pontifex Industries</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<!-- App Store encryption export compliance — HTTPS only (exempt from EAR) -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- Privacy usage descriptions — required by App Store -->
	<!-- Location: used once at clock-in to verify the employee is physically
	     at the job site. No continuous or background tracking. Apple's
	     automated checker (90683) requires both keys when any linked SDK
	     references location APIs, even if "always on" is never requested. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Pontifex verifies you are at the job site when you clock in. Your location is checked once per clock-in event and is not tracked in the background.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Pontifex verifies you are at the job site when you clock in. Your location is only used during the clock-in check and is never tracked in the background.</string>
	<key>NSCameraUsageDescription</key>
	<string>Pontifex uses the camera to capture job site photos and document completed work.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Pontifex uses the microphone for voice-based equipment checkout and job notes.</string>
	<!-- NFCReaderUsageDescription removed: the iOS app has no native NFC (badge
	     scanning is Android-only via Web NFC; iOS uses a PIN fallback). -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Pontifex saves job site photos to your photo library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Pontifex accesses your photo library to attach images to job reports.</string>
</dict>
</plist>
