# ============================================================
# Patriot Concrete Cutting — Production Environment Variables
# Copy to .env.local and fill in real values
# ============================================================

# ─── Supabase (REQUIRED) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://klatddoyncxidgqtcjnu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URLs (REQUIRED for production) ──────────────────────
NEXT_PUBLIC_SITE_URL=https://app.patriotconcretecutting.com
NEXT_PUBLIC_APP_URL=https://app.patriotconcretecutting.com
NEXT_PUBLIC_APP_VERSION=1.0.0

# ─── Google Maps (REQUIRED for GPS/routing) ──────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key
GOOGLE_MAPS_API_KEY=your-google-maps-server-key
# Set to 'true' to fully disable Google Maps (use plain-text address input).
# Useful when Google Cloud billing isn't enabled and you don't want the
# script to load and error in the dev console.
# NEXT_PUBLIC_DISABLE_GOOGLE_MAPS=true

# ─── Email — Resend (REQUIRED for notifications) ─────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=Patriot Concrete Cutting <noreply@patriotconcretecutting.com>

# ─── SMS — Telnyx (OPTIONAL — for job notifications) ─────────
TELNYX_API_KEY=your-telnyx-api-key
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX

# ─── SMS — Twilio (OPTIONAL — legacy, Telnyx preferred) ──────
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── Email — SendGrid (OPTIONAL — for silica plans) ──────────
# SENDGRID_API_KEY=your-sendgrid-key

# ─── Testing ─────────────────────────────────────────────────
# Setting this enables a "Testing bypass" UI button on the clock-in flow.
# Operators must enter this code to skip GPS verification (useful when
# testing from home). Without this var set, the bypass is impossible.
# NEVER set this in production.
# NEXT_PUBLIC_LOCATION_BYPASS_CODE=4242
