# =============================================================================
# Pontifex Industries Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local or any file containing real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com
# Find these in: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Your Supabase project URL (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase service role key — KEEP SECRET! Only used server-side (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# -----------------------------------------------------------------------------
# Email — Resend (https://resend.com)
# Find your API key at: https://resend.com/api-keys
# -----------------------------------------------------------------------------

# Resend API key for sending transactional emails
RESEND_API_KEY=re_your_resend_api_key_here

# From address used in outgoing emails (must be verified in Resend)
RESEND_FROM_EMAIL=Your Company <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Public URL of the deployed app (used for links in emails, redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google Maps — https://console.cloud.google.com/google/maps-apis
# Enable "Places API" and "Maps JavaScript API" for your project
# -----------------------------------------------------------------------------

# Google Maps API key (public — exposed in browser for map rendering)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Set to "true" to bypass GPS/location verification during development.
# REMOVE THIS OR SET TO "false" IN PRODUCTION — never use in production!
NEXT_PUBLIC_BYPASS_LOCATION_CHECK=false

# -----------------------------------------------------------------------------
# SMS — Twilio (https://console.twilio.com)
# Used for job assignment notifications and operator alerts
# -----------------------------------------------------------------------------

# Twilio Account SID — found on the Twilio Console dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token — found on the Twilio Console dashboard (keep secret)
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here

# Twilio phone number to send SMS from (E.164 format, e.g. +18005551234)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# -----------------------------------------------------------------------------
# SMS — Telnyx (alternative to Twilio, https://telnyx.com)
# Uncomment and fill in if using Telnyx instead of Twilio
# -----------------------------------------------------------------------------

# TELNYX_API_KEY=your-telnyx-api-key-here
# TELNYX_PHONE_NUMBER=+1XXXXXXXXXX
# TELNYX_MESSAGING_PROFILE_ID=your-messaging-profile-id-here
